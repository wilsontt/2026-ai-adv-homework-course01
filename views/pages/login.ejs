<div id="app">
  <div class="flex min-h-[calc(100vh-72px)]">

    <!-- Left: Brand Panel -->
    <div class="hidden md:flex relative w-1/2 overflow-hidden">
      <img
        src="https://images.unsplash.com/photo-1508610048659-a06b669e3321?w=1200&q=80"
        alt="花漾生活"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0" style="background:linear-gradient(to top,#1D3A1Ecc 0%,#1D3A1E55 50%,#1D3A1E22 100%);"></div>
      <div class="relative flex flex-col justify-end gap-4 p-14 pb-16 w-full">
        <p class="font-serif-display italic text-3xl font-normal text-white leading-snug" style="line-height:1.35;">
          「每一束花，<br>都是一份用心的禮物」
        </p>
        <p class="text-floral-gold text-sm">— 花漾生活</p>
      </div>
    </div>

    <!-- Right: Auth Form -->
    <div class="flex-1 flex items-center justify-center bg-white px-8 py-12">
      <div class="w-full max-w-md flex flex-col gap-8">

        <div>
          <h1 class="font-serif-display font-bold text-4xl text-text-primary mb-2">
            {{ activeTab === 'login' ? '歡迎回來' : '建立帳號' }}
          </h1>
          <p class="text-text-secondary text-sm">
            {{ activeTab === 'login' ? '登入您的帳號，查看訂單與會員優惠' : '加入花漾生活，享受專屬會員服務' }}
          </p>
        </div>

        <!-- Tabs -->
        <div class="flex border-b-2 border-floral-border">
          <button
            @click="activeTab = 'login'; errors = {}"
            class="flex-1 pb-3 text-sm font-semibold transition-colors border-b-2 -mb-0.5"
            :class="activeTab === 'login' ? 'border-floral-green text-floral-green' : 'border-transparent text-text-muted hover:text-text-secondary'"
          >登入</button>
          <button
            @click="activeTab = 'register'; errors = {}"
            class="flex-1 pb-3 text-sm font-semibold transition-colors border-b-2 -mb-0.5"
            :class="activeTab === 'register' ? 'border-floral-green text-floral-green' : 'border-transparent text-text-muted hover:text-text-secondary'"
          >註冊</button>
        </div>

        <!-- Login Form -->
        <form v-if="activeTab === 'login'" @submit.prevent="handleLogin" class="flex flex-col gap-5">
          <div>
            <label class="block text-sm font-medium text-text-primary mb-1.5">電子郵件</label>
            <div class="relative">
              <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-text-muted">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </span>
              <input
                v-model="loginForm.email"
                type="email"
                placeholder="請輸入您的 Email"
                class="w-full pl-10 pr-4 py-3 border rounded text-sm focus:outline-none transition-colors"
                :class="errors.email ? 'border-floral-rose' : 'border-floral-border focus:border-floral-green'"
              />
            </div>
            <p v-if="errors.email" class="text-floral-rose text-xs mt-1.5">{{ errors.email }}</p>
          </div>

          <div>
            <div class="flex justify-between mb-1.5">
              <label class="text-sm font-medium text-text-primary">密碼</label>
              <a href="#" class="text-xs text-floral-green hover:underline">忘記密碼？</a>
            </div>
            <div class="relative">
              <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-text-muted">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              </span>
              <input
                v-model="loginForm.password"
                type="password"
                placeholder="請輸入密碼"
                class="w-full pl-10 pr-4 py-3 border rounded text-sm focus:outline-none transition-colors"
                :class="errors.password ? 'border-floral-rose' : 'border-floral-border focus:border-floral-green'"
              />
            </div>
            <p v-if="errors.password" class="text-floral-rose text-xs mt-1.5">{{ errors.password }}</p>
          </div>

          <button
            type="submit"
            :disabled="submitting"
            class="w-full bg-floral-green text-white font-semibold py-3.5 rounded text-sm hover:bg-floral-green-mid transition-colors disabled:opacity-50"
          >
            {{ submitting ? '登入中…' : '登入' }}
          </button>

          <p class="text-center text-sm text-text-secondary">
            還沒有帳號？
            <button type="button" @click="activeTab = 'register'; errors = {}" class="text-floral-rose font-semibold hover:underline">立即註冊</button>
          </p>
        </form>

        <!-- Register Form -->
        <form v-else @submit.prevent="handleRegister" class="flex flex-col gap-5">
          <div>
            <label class="block text-sm font-medium text-text-primary mb-1.5">姓名</label>
            <input
              v-model="registerForm.name"
              type="text"
              placeholder="請輸入您的姓名"
              class="w-full border rounded px-4 py-3 text-sm focus:outline-none transition-colors"
              :class="errors.name ? 'border-floral-rose' : 'border-floral-border focus:border-floral-green'"
            />
            <p v-if="errors.name" class="text-floral-rose text-xs mt-1.5">{{ errors.name }}</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-text-primary mb-1.5">電子郵件</label>
            <input
              v-model="registerForm.email"
              type="email"
              placeholder="請輸入 Email 地址"
              class="w-full border rounded px-4 py-3 text-sm focus:outline-none transition-colors"
              :class="errors.email ? 'border-floral-rose' : 'border-floral-border focus:border-floral-green'"
            />
            <p v-if="errors.email" class="text-floral-rose text-xs mt-1.5">{{ errors.email }}</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-text-primary mb-1.5">密碼</label>
            <input
              v-model="registerForm.password"
              type="password"
              placeholder="至少 6 個字元"
              class="w-full border rounded px-4 py-3 text-sm focus:outline-none transition-colors"
              :class="errors.password ? 'border-floral-rose' : 'border-floral-border focus:border-floral-green'"
            />
            <p v-if="errors.password" class="text-floral-rose text-xs mt-1.5">{{ errors.password }}</p>
          </div>

          <button
            type="submit"
            :disabled="submitting"
            class="w-full bg-floral-green text-white font-semibold py-3.5 rounded text-sm hover:bg-floral-green-mid transition-colors disabled:opacity-50"
          >
            {{ submitting ? '註冊中…' : '建立帳號' }}
          </button>

          <p class="text-center text-sm text-text-secondary">
            已有帳號？
            <button type="button" @click="activeTab = 'login'; errors = {}" class="text-floral-green font-semibold hover:underline">立即登入</button>
          </p>
        </form>

      </div>
    </div>

  </div>
</div>
