<div id="app">

  <div v-if="loading" class="flex justify-center py-24">
    <span class="w-8 h-8 border-2 border-floral-green border-t-transparent rounded-full animate-spin inline-block"></span>
  </div>

  <div v-else-if="orders.length === 0" class="max-w-7xl mx-auto px-8 py-24 text-center">
    <div class="text-6xl mb-5">📦</div>
    <h2 class="font-serif-display font-bold text-2xl text-text-primary mb-2">尚無訂單</h2>
    <p class="text-text-muted text-sm mb-8">快去選購喜歡的花束吧！</p>
    <a href="/" class="inline-block bg-floral-green text-white font-semibold px-8 py-3 rounded text-sm hover:bg-floral-green-mid transition-colors">去逛逛</a>
  </div>

  <div v-else class="max-w-7xl mx-auto px-8 py-10">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
      <div>
        <h1 class="font-serif-display font-bold text-4xl text-text-primary mb-1">我的訂單</h1>
        <p class="text-text-muted text-sm">共 {{ orders.length }} 筆訂單記錄</p>
      </div>
    </div>

    <div class="flex flex-col gap-4">
      <a
        v-for="order in orders"
        :key="order.id"
        :href="'/orders/' + order.id"
        class="block bg-white rounded-lg border border-floral-border hover:shadow-md transition-shadow overflow-hidden"
      >
        <!-- Card Header -->
        <div class="flex items-center justify-between px-6 py-4 border-b border-floral-border/60">
          <div>
            <p class="text-sm font-medium text-text-primary">訂單編號：{{ order.order_no }}</p>
            <p class="text-xs text-text-muted mt-0.5">{{ new Date(order.created_at).toLocaleDateString('zh-TW') }}</p>
          </div>
          <span
            class="text-xs font-semibold px-3 py-1.5 rounded"
            :class="statusMap[order.status]?.cls || 'bg-gray-100 text-gray-600'"
          >
            {{ statusMap[order.status]?.label || order.status }}
          </span>
        </div>
        <!-- Card Footer -->
        <div class="flex items-center justify-between px-6 py-4">
          <p class="text-sm text-text-secondary">{{ order.recipient_name }} · {{ order.recipient_address }}</p>
          <div class="flex items-center gap-4">
            <span class="font-bold text-text-primary text-lg font-serif-display">NT${{ order.total_amount.toLocaleString() }}</span>
            <span class="text-text-muted text-sm flex items-center gap-1">
              查看詳情
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </span>
          </div>
        </div>
      </a>
    </div>

  </div>

</div>
