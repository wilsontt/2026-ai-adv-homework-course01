<div id="app" data-product-id="<%= productId %>">

  <div v-if="loading" class="flex justify-center py-24">
    <span class="w-8 h-8 border-2 border-floral-green border-t-transparent rounded-full animate-spin inline-block"></span>
  </div>

  <div v-else-if="notFound" class="text-center py-24">
    <div class="text-6xl mb-5">🌸</div>
    <h2 class="text-xl font-semibold text-text-primary mb-3">找不到此商品</h2>
    <a href="/" class="text-sm text-floral-green hover:underline">回到首頁</a>
  </div>

  <div v-else-if="product" class="max-w-7xl mx-auto px-8 py-10">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-text-muted mb-8">
      <a href="/" class="hover:text-floral-green transition-colors">首頁</a>
      <span>/</span>
      <a href="/#products" class="hover:text-floral-green transition-colors">花藝商品</a>
      <span>/</span>
      <span class="text-text-primary">{{ product.name }}</span>
    </nav>

    <div class="flex flex-col md:flex-row gap-14">

      <!-- Left: Image -->
      <div class="md:w-1/2 flex flex-col gap-4">
        <div class="rounded-lg overflow-hidden bg-floral-bg-alt" style="aspect-ratio:1;">
          <img
            :src="product.image_url || 'https://images.unsplash.com/photo-1490750967868-88aa4f44baee?w=800'"
            :alt="product.name"
            class="w-full h-full object-cover"
          />
        </div>
        <!-- Thumbnail row (static decorative) -->
        <div class="grid grid-cols-4 gap-3">
          <div
            v-for="n in 4" :key="n"
            class="rounded overflow-hidden bg-floral-bg-alt cursor-pointer hover:ring-2 hover:ring-floral-green transition-all"
            style="aspect-ratio:1;"
          >
            <img
              :src="product.image_url || 'https://images.unsplash.com/photo-1490750967868-88aa4f44baee?w=200'"
              :alt="product.name"
              class="w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity"
            />
          </div>
        </div>
      </div>

      <!-- Right: Info -->
      <div class="md:w-1/2 flex flex-col gap-7">

        <div class="flex flex-col gap-3">
          <p class="text-[10px] font-semibold tracking-[0.25em] text-floral-rose uppercase">季節花束 · SEASONAL BOUQUET</p>
          <h1 class="font-serif-display font-bold text-text-primary" style="font-size:2.6rem;line-height:1.15;">
            {{ product.name }}
          </h1>
          <div class="flex items-baseline gap-4">
            <span class="text-floral-rose font-bold text-3xl">NT$&nbsp;{{ product.price.toLocaleString() }}</span>
          </div>
          <div v-if="product.stock > 0" class="flex items-center gap-2 text-sm text-floral-green">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            尚有 {{ product.stock }} 件庫存
          </div>
          <div v-else class="text-sm text-text-muted">目前無庫存</div>
        </div>

        <div class="h-px bg-floral-border"></div>

        <p class="text-text-secondary leading-relaxed text-base">{{ product.description }}</p>

        <!-- Qty Selector -->
        <div class="flex flex-col gap-3">
          <label class="text-sm font-medium text-text-secondary">數量</label>
          <div class="inline-flex items-center border border-floral-border rounded bg-white overflow-hidden w-fit">
            <button
              @click="decrease"
              :disabled="quantity <= 1"
              class="w-11 h-11 flex items-center justify-center text-text-secondary hover:bg-floral-green-light transition-colors disabled:opacity-30"
            >−</button>
            <span class="w-14 h-11 flex items-center justify-center text-sm font-semibold text-text-primary border-x border-floral-border">
              {{ quantity }}
            </span>
            <button
              @click="increase"
              :disabled="!product || quantity >= product.stock"
              class="w-11 h-11 flex items-center justify-center text-text-secondary hover:bg-floral-green-light transition-colors disabled:opacity-30"
            >+</button>
          </div>
        </div>

        <!-- CTA -->
        <div class="flex items-center gap-3">
          <button
            @click="addToCart"
            :disabled="adding || product.stock <= 0"
            class="flex-1 flex items-center justify-center gap-2 bg-floral-green text-white font-semibold py-3.5 rounded hover:bg-floral-green-mid transition-colors disabled:opacity-40 text-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            {{ product.stock <= 0 ? '已售完' : (adding ? '加入中…' : '加入購物車') }}
          </button>
          <button class="w-12 h-12 flex items-center justify-center border border-floral-border rounded hover:bg-floral-rose-light transition-colors text-text-muted hover:text-floral-rose">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </button>
        </div>

        <!-- Purchase Notes -->
        <div class="bg-floral-rose-light rounded-lg p-5 flex flex-col gap-2.5 border-l-4 border-floral-rose">
          <h3 class="text-sm font-semibold text-text-primary">購買須知</h3>
          <ul class="text-xs text-text-secondary space-y-1.5">
            <li class="flex items-start gap-2"><span class="text-floral-rose mt-0.5">🌿</span>花材依季節供應，實際花束可能略有差異</li>
            <li class="flex items-start gap-2"><span class="text-floral-rose mt-0.5">🌿</span>台北市區可享當日配送服務</li>
            <li class="flex items-start gap-2"><span class="text-floral-rose mt-0.5">🌿</span>消費滿 NT$500 享免運優惠</li>
          </ul>
        </div>

        <!-- Delivery -->
        <div class="flex items-center gap-8 text-sm text-text-secondary">
          <div class="flex items-center gap-2">
            <span class="text-floral-green">🚚</span>台北市區當日配送
          </div>
          <div class="flex items-center gap-2">
            <span class="text-floral-green">🛡️</span>品質保證退換
          </div>
        </div>

      </div>
    </div>
  </div>

</div>
